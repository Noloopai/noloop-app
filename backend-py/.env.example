# NoLoop backend (Python/FastAPI) — environment.
#
# Copy this file to `.env` and fill in the same values your NestJS backend used,
# so the Python API talks to the SAME Supabase database and issues compatible
# JWTs. (The web + admin frontends keep pointing at http://localhost:4000.)

# Pooled connection (app runtime). Same value as the NestJS backend's DATABASE_URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require

# Direct connection (not used at runtime; kept for parity / tooling).
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# MUST match the NestJS backend so existing tokens keep working.
JWT_SECRET=change-me-to-the-same-secret-as-the-nest-backend
JWT_EXPIRES_IN=7d

# The Python AI adjudication engine (noloop-app/ai), default port 8000.
AI_ENGINE_URL=http://localhost:8000

# Port this API listens on. The frontends expect 4000.
API_PORT=4000
